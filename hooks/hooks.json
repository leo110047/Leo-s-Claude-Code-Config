{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "安裝後請將此檔案內容合併到 ~/.claude/settings.json，並將 ${HOOKS_DIR} 替換為實際路徑",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git stash*)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cd)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(tee *)",
      "Bash(xargs *)",
      "Bash(test *)",
      "Bash([ *)",
      "Bash(export *)",
      "Bash(env *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(curl *)",
      "Bash(chmod *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(jq *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(basename *)",
      "Bash(dirname *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(chmod 777 *)",
      "Bash(> /dev/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/dev-server-blocker.js\""
          }
        ],
        "description": "Block dev servers outside tmux"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/git-push-reminder.js\""
          }
        ],
        "description": "Reminder before git push"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/doc-file-blocker.js\""
          }
        ],
        "description": "Block creation of random .md files"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/detect-secrets.js\""
          }
        ],
        "description": "Detect and block secrets in file content"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/context-monitor.js\""
          }
        ],
        "description": "Monitor context usage and suggest /compact at high utilization"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/post-edit-format.js\""
          }
        ],
        "description": "Auto-format JS/TS files with Prettier after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/post-edit-typecheck.js\""
          }
        ],
        "description": "TypeScript check after editing .ts/.tsx files"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/post-edit-console-warn.js\""
          }
        ],
        "description": "Warn about console.log statements after edits"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/check-console-log.js\""
          }
        ],
        "description": "Check for console.log in modified files after each response"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/notify-desktop.js\""
          }
        ],
        "description": "Desktop notification when response completes (only when terminal is not focused)"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "general-purpose",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Review the subagent's final output. Check: (1) Did it claim completion? If so, does the output contain concrete evidence (file paths, test results, command output) — not just 'Done!' or 'All set!'? (2) Are there red flags like 'should work', 'probably', or missing verification steps? If the output lacks evidence of completion, respond with a brief note about what verification is missing. If the output contains proper evidence, respond with 'LGTM'.",
            "timeout": 30
          }
        ],
        "description": "Lightweight spec review for general-purpose subagent output"
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOOKS_DIR}/scripts/hooks/notify-desktop.js\""
          }
        ],
        "description": "Desktop notification for permission prompts and questions"
      }
    ]
  }
}
